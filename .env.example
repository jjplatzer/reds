# ─── Solace / SWIM connection ───────────────────────────────────────────────────────
# ─── Replace dots with your credentials ─────────────────────────────────────────────
#
# These credentials are only needed if USE_SERVER=false.

SMES_JMS_URL=...
SMES_VPN=...
SCDS_USERNAME=...
SCDS_PASSWORD=...
SMES_QUEUE=...

# If true, REDS uses the public REDS live server instead of the credentials above.
# If omitted entirely, REDS defaults to USE_SERVER=true.
USE_SERVER=true
