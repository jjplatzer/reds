# ─── Solace / SWIM connection ───────────────────────────────────────────────────────
# ─── Replace dots with your credentials ─────────────────────────────────────────────
#
# These credentials are only needed if USE_PUBLIC_SERVER=false.

SMES_JMS_URL=...
SMES_VPN=...
SCDS_USERNAME=...
SCDS_PASSWORD=...
SMES_QUEUE=...

# If true, REDS uses the public REDS live server instead of the credentials above.
# If omitted entirely, REDS defaults to USE_PUBLIC_SERVER=true.
USE_PUBLIC_SERVER=true

# Optional playback API override for local server testing.
# If omitted, REDS uses the public playback API when USE_PUBLIC_SERVER=true.
# PLAYBACK_BASE_URL=http://localhost:8080/playback
